# demo keeps the application fully runnable without Scaleway credentials.
# Set SCW_MODE=live to call Scaleway APIs.
SCW_MODE=demo
PORT=3000

# Scaleway API configuration.
SCW_SECRET_KEY=
SCW_ORGANIZATION_ID=
SCW_PROJECT_ID=
SCW_REGION=fr-par
SCW_BASE_URL=https://api.scaleway.com

# Scheduler and detection tuning.
SCW_POLL_INTERVAL_SECONDS=60
SCW_LOOKBACK_MINUTES=60
FAILED_LOGIN_THRESHOLD=3
FAILED_LOGIN_WINDOW_MINUTES=15
ALLOWED_COUNTRY_CODES=FR,IN,SE

# Local persistence and logging.
DATA_DIR=./data
LOG_DIR=./logs
